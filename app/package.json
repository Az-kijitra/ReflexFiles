{
  "name": "app",
  "version": "0.4.0",
  "description": "",
  "type": "module",
  "scripts": {
    "sync:version": "node scripts/sync_version.mjs",
    "dev": "node scripts/sync_version.mjs && node scripts/build_manual.mjs && vite dev",
    "build": "node scripts/sync_version.mjs && node scripts/build_manual.mjs && vite build",
    "docs:keymap-main": "node --experimental-strip-types scripts/build_keyboard_behavior_doc.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "test:keys": "node --experimental-strip-types scripts/tests/run-key-tests.mjs",
    "test:dnd": "node --experimental-strip-types scripts/tests/run-dnd-foundation-tests.mjs",
    "audit:npm": "npm audit --audit-level=high",
    "audit:npm:prod": "npm audit --omit=dev --audit-level=high",
    "audit:cargo": "cargo audit --file src-tauri/Cargo.lock",
    "audit:deps": "npm run audit:npm && npm run audit:cargo",
"tauri": "tauri",
    "release:precheck": "node scripts/release/precheck.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
"svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
